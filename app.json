{
  "expo": {
    "name": "ZimFarm",
    "slug": "zimfarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zimfarm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.zw.zimfarm",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ZimFarm uses your location to show local weather and market prices.",
        "NSCameraUsageDescription": "ZimFarm uses the camera to diagnose crop health issues.",
        "NSPhotoLibraryUsageDescription": "ZimFarm uses your photos for profile and community posts.",
        "NSUserNotificationsUsageDescription": "ZimFarm sends reminders for your farming tasks."
      }
    },
    "android": {
      "package": "co.zw.zimfarm",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SEND_SMS",
        "READ_SMS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "FarmBridge uses your photos for your profile picture.",
          "cameraPermission": "FarmBridge uses your camera for your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
